{
  "scripts": {
    // RUN FOR DEVELOPMENT:
    "dev": "dotenv -- pnpm --filter=@core-service/* --recursive --parallel run dev",

    // BUILD:
    "build": "dotenv -- pnpm --filter=@core* --recursive run build",

    // LINTING & FORMATTING:
    "lint": "pnpm --filter=@core* --recursive --parallel run lint",
    "lint:fix": "pnpm --filter=@core* --recursive --parallel run lint:fix",

    "ts:check": "pnpm --filter=@core* --recursive --parallel run ts:check",

    // DEPENDENCY MANAGEMENT:
    "update": "pnpm --filter=@core* --recursive up -i -L"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "dotenv-cli": "^11.0.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  }
}